<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is intentionally OFF for this personal app so the
	     embedded login WebView and InnerTube requests have unrestricted
	     network + cookie access. Do not ship this to the App Store as-is. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
